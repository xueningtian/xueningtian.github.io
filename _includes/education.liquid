<div class="education">
  {% if page.education != blank %}
    {% assign edu_size = page.education | size %}
    <div
      class="table-responsive"
      {% if edu_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% for edu in page.education %}
          <tr>
            <th scope="row" style="width: 20%">{{ edu.dates }}</th>
            <td>
              <strong>{{ edu.degree }}</strong><br />
              <em>{{ edu.institution }}</em><br />
              {% if edu.description %}<span>{{ edu.description }}</span>{% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No education listed...</p>
  {% endif %}
</div>
